{
  "manifest_version": 3,
  "name": "YT Downloader",
  "version": "1.0.0",
  "description": "Download YouTube videos and music with quality selection",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "clipboardRead"
  ],
  "host_permissions": [
    "http://localhost:7979/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
